  43:Generated_Source\PSoC6\pdl\drivers/peripheral/scb/cy_scb_uart.h **** * * IrDA
  44:Generated_Source\PSoC6\pdl\drivers/peripheral/scb/cy_scb_uart.h **** * * Data frame size programmable from 4 to 16 bits
