  93:main_cm0p.c   **** static void WriteBurst(uint8 reg_addr, const uint8 *data, uint16 length)
  94:main_cm0p.c   **** {
  95:main_cm0p.c   ****     uint16 i;
  96:main_cm0p.c   **** 
  97:main_cm0p.c   ****     burstBuff[0] = reg_addr;   // first byte = register address
