 112:main_cm0p.c   **** static void BMI270_UploadConfig(const uint8 *config_file, uint16 config_size)
 113:main_cm0p.c   **** {
 114:main_cm0p.c   ****     uint16 index = 0;
 115:main_cm0p.c   ****     uint16 chunk;
 116:main_cm0p.c   **** 
 117:main_cm0p.c   ****     while(index < config_size)
 118:main_cm0p.c   ****     {
 119:main_cm0p.c   ****         chunk = config_size - index;
 120:main_cm0p.c   **** 
 121:main_cm0p.c   ****         if(chunk > 32)
 122:main_cm0p.c   ****         {
 123:main_cm0p.c   ****             chunk = 32;
 124:main_cm0p.c   ****         }
 125:main_cm0p.c   **** 
 126:main_cm0p.c   ****         WriteBurst(0x5E, &config_file[index], chunk);   // INIT_DATA
 127:main_cm0p.c   ****         index += chunk;
 128:main_cm0p.c   ****     }
 129:main_cm0p.c   **** }
