  99:main_cm0p.c   ****     for(i = 0; i < length; i++)
 100:main_cm0p.c   ****     {
 101:main_cm0p.c   ****         burstBuff[i + 1] = data[i];
 102:main_cm0p.c   ****     }
 103:main_cm0p.c   **** 
 104:main_cm0p.c   ****     register_setting.buffer = burstBuff;
 105:main_cm0p.c   ****     register_setting.bufferSize = length + 1;
 106:main_cm0p.c   ****     register_setting.xferPending = false;
 107:main_cm0p.c   **** 
 108:main_cm0p.c   ****     SensorBus_MasterWrite(&register_setting);
 109:main_cm0p.c   ****     WaitForOperation();
 110:main_cm0p.c   **** }
