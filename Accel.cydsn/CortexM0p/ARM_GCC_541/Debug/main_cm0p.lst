  79:main_cm0p.c   **** static void BMI270_PrepareConfigLoad(void)
  80:main_cm0p.c   **** {
  81:main_cm0p.c   ****     // Disable advanced power save: PWR_CONF[0] = adv_power_save = 0
  82:main_cm0p.c   ****     WriteRegister(0x7C, 0x00);
  83:main_cm0p.c   ****     CyDelayUs(500);   // Bosch says >= 450 us
  84:main_cm0p.c   **** 
  85:main_cm0p.c   ****     // Prepare config load
